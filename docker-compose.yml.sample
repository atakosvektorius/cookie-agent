services:
  cookie-agent:
    image: cookie-agent:latest
    deploy:
      replicas: 5
      restart_policy:
        condition: any
        delay: 5s
      update_config:
        parallelism: 1
        order: start-first
    environment:
      API_KEY: "abcdef0123456789abcdef0123456789"
      GET_WORK_URL: "http://172.17.0.1/api/admin/cookies/getwork"
      PUSH_RESULTS_URL: "http://172.17.0.1/api/admin/cookies/push"
      HEALTHCHECK_FILE: "/tmp/healthcheck.log"
      GECKODRIVER_PATH: "/usr/bin/geckodriver"
      LIMIT: 10
      DB_PATH: "/data/cookie_agent.db"
    # volumes:
    #   - ./data:/data
    tmpfs:
      - /dev/shm:size=2g
    dns:
      - 1.1.1.1
    tty: true
    healthcheck:
      test: ["CMD-SHELL", "test -f /tmp/healthcheck.log && test $$(($$(date +%s) - $$(stat -c %Y /tmp/healthcheck.log))) -lt 120"]
      interval: 60s
      timeout: 30s
      retries: 3
      start_period: 60s

  cookie-agent-deleted:
    image: cookie-agent:latest
    deploy:
      replicas: 1
      restart_policy:
        condition: any
        delay: 5s
    environment:
      API_KEY: "abcdef0123456789abcdef0123456789"
      GET_WORK_URL: "http://172.17.0.1/api/admin/deletedcookies/getwork"
      PUSH_RESULTS_URL: "http://172.17.0.1/api/admin/cookies/push"
      HEALTHCHECK_FILE: "/tmp/healthcheck.log"
      GECKODRIVER_PATH: "/usr/bin/geckodriver"
      LIMIT: 10
      DB_PATH: "/data/cookie_agent.db"
    # volumes:
    #   - ./data:/data
    tmpfs:
      - /dev/shm:size=2g
    dns:
      - 1.1.1.1
    tty: true
    healthcheck:
      test: ["CMD-SHELL", "test -f /tmp/healthcheck.log && test $$(($$(date +%s) - $$(stat -c %Y /tmp/healthcheck.log))) -lt 120"]
      interval: 60s
      timeout: 30s
      retries: 3
      start_period: 60s
